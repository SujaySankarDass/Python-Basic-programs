def get_subject():
	subjects = []
	
	while True:
		subject_name = input("Enter name of the Subject: ")
		
		if subject_name == "":
			print("All subject stored")
			break
		else:
			subjects.append(subject_name)
			print("Subject added")
			
	print("\nEntered subjects are:")
	for sub in subjects:
		print(sub)

get_subject()